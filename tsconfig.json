{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"nativewind-env.d.ts"
	],
	"exclude": ["node_modules"]
}
